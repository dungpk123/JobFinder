# Email Configuration
# Sử dụng Gmail - Bạn cần tạo App Password trong Google Account
# Hướng dẫn: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# OpenAI (AI assistant)
# IMPORTANT: Không commit file server/.env lên git.
OPENAI_API_KEY=
# Ví dụ: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Gemini (Google AI Studio)
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Ví dụ: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Chọn nhà cung cấp AI: gemini | openai
AI_PROVIDER=gemini

# Optional: Gmail OAuth2 (không cần 2FA/App Password)
# Cần tạo project Google Cloud, bật Gmail API, tạo OAuth Client (Desktop App)
# Sau đó lấy Refresh Token (OAuth Playground) và điền vào dưới đây
# Nếu các biến này có giá trị, hệ thống sẽ dùng OAuth2 để gửi mail
EMAIL_OAUTH_CLIENT_ID=
EMAIL_OAUTH_CLIENT_SECRET=
EMAIL_OAUTH_REFRESH_TOKEN=

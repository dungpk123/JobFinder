# Email Configuration
# Sử dụng Gmail - Bạn cần tạo App Password trong Google Account
# Hướng dẫn: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# Nhà cung cấp email: smtp | resend | gmail_api
# Khuyến nghị trên Render khi SMTP Gmail timeout: dùng gmail_api
EMAIL_PROVIDER=gmail_api
# Khi dùng Resend API, thêm key bên dưới và đặt EMAIL_FROM là sender đã xác minh
RESEND_API_KEY=
EMAIL_FROM=your-email@gmail.com
# Timeout gửi email (ms). Mặc định: 45000 ở production, 15000 ở development.
EMAIL_TIMEOUT_MS=45000
# SMTP cấu hình tường minh (tránh timeout khi provider dùng cổng khác)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_REQUIRE_TLS=true
# Bật tạm để trả OTP trực tiếp trong response khi mail lỗi (KHÔNG nên để true lâu dài ở production)
EXPOSE_OTP_IN_RESPONSE=false

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# Prisma / TiDB Serverless
# Ví dụ: mysql://USER:PASSWORD@HOST:4000/DBNAME?sslaccept=strict
DATABASE_URL=mysql://user:password@host:4000/dbname?sslaccept=strict

# Frontend domains được phép gọi API
# Ví dụ: http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app

# Môi trường chạy backend
NODE_ENV=development
PORT=3001

# OpenAI (AI assistant)
# IMPORTANT: Không commit file server/.env lên git.
OPENAI_API_KEY=
# Ví dụ: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Gemini (Google AI Studio)
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Ví dụ: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Chọn nhà cung cấp AI: gemini | openai
AI_PROVIDER=gemini

# Cloudinary (lưu ảnh avatar/logo)
# Cách 1: dùng 3 biến riêng
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Cách 2: dùng URL đầy đủ (chỉ cần 1 biến)
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Gmail OAuth2 (bắt buộc khi EMAIL_PROVIDER=gmail_api)
# Cần tạo project Google Cloud, bật Gmail API, tạo OAuth Client (Desktop App)
# Sau đó lấy Refresh Token (OAuth Playground) và điền vào dưới đây
# Cần cấp scope: https://mail.google.com/
EMAIL_OAUTH_CLIENT_ID=
EMAIL_OAUTH_CLIENT_SECRET=
EMAIL_OAUTH_REFRESH_TOKEN=
